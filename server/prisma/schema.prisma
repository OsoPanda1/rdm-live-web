generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// GEMELOS DIGITALES · TELEMETRÍA & OBSERVABILIDAD
// =====================================================

model DigitalTwin {
  id          String     @id @default(cuid())
  modelType   TwinType
  modelId     String?
  sourceId    String
  status      TwinStatus @default(ACTIVE)

  /// Telemetría cruda (sensores, eventos, latencias, métricas de salud)
  telemetry   Json       @default("{}")
  /// Propiedades “lentas”: configuración, capacidades declaradas, límites
  properties  Json       @default("{}")
  /// Metadata extendida: etiquetas, versión de modelo, checksums, etc.
  metadata    Json       @default("{}")

  /// Huella para futuros esquemas híbridos pre/post‑cuántum (ej. hash en MSR)
  quantumFingerprint String? @db.VarChar(255)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([sourceId, modelType])
  @@index([modelType, status])
  @@index([status, updatedAt])
}

enum TwinType {
  PLACE_TWIN
  MERCHANT_TWIN
  ROUTE_TWIN
  AGENT_TWIN
}

enum TwinStatus {
  ACTIVE
  INACTIVE
  SIMULATING
  MAINTENANCE
}

// =====================================================
// ENTIDADES TURÍSTICAS
// =====================================================

model Place {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String    @db.Text
  type        String
  latitude    Float
  longitude   Float
  altitude    Float?
  city        String    @default("Real del Monte")
  state       String    @default("Hidalgo")
  country     String    @default("México")
  metadata    Json      @default("{}")
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([city])
  @@index([state])
  @@index([latitude, longitude])
  @@index([type, isFeatured])
}

model Merchant {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  category        String
  immersionLevel  Int      @default(1)
  description     String   @db.Text
  priceRange      String
  address         String
  latitude        Float?
  longitude       Float?
  city            String   @default("Real del Monte")
  state           String   @default("Hidalgo")
  country         String   @default("México")
  phone           String?
  website         String?
  mainImage       String?
  tags            String[]
  pciCompliance   Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category, isActive])
  @@index([city])
  @@index([latitude, longitude])
}

model Route {
  id           String      @id @default(cuid())
  slug         String      @unique
  name         String
  theme        String
  difficulty   String      @default("EASY")
  fitnessScore Float       @default(0.0)
  stops        RouteStop[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model RouteStop {
  id      String @id @default(cuid())
  order   Int
  placeId String
  routeId String

  route   Route  @relation(fields: [routeId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  startDate   DateTime
  endDate     DateTime
  location    String
  image       String?
}

model Legend {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String   @db.Text
  tags        String[]
}

model Saying {
  id          String   @id @default(cuid())
  phrase      String
  meaning     String   @db.Text
  origin      String?
}

// =====================================================
// USUARIOS Y COMERCIO
// =====================================================

enum Role {
  VISITOR
  MERCHANT
  ADMIN
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String?
  role         Role          @default(VISITOR)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  donations    Donation[]
  interactions Interaction[]
  aiLogs       AiInteractionLog[]
}

model Donation {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  amount     Int
  currency   String   @default("mxn")
  provider   String   @default("stripe")
  providerId String

  /// requestId que generas en la ruta /donations (para trazabilidad completa)
  requestId  String?  @db.VarChar(100)

  /// Hash o ID externo (p.ej. ancla en MSR Blockchain / Evidence Chain)
  ledgerAnchor String? @db.VarChar(255)

  /// Metadatos para telemetría / observabilidad (IP, UA, tags, etc.)
  telemetry  Json     @default("{}")

  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([provider, providerId])
  @@index([userId, createdAt])
}

model Interaction {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  kind       String
  businessId String?
  context    String?
  createdAt  DateTime @default(now())

  @@index([userId, kind, createdAt])
}

// =====================================================
// IA / REALITO · TELEMETRÍA COGNITIVA
// =====================================================

model AiInteractionLog {
  id          String   @id @default(cuid())
  userId      String
  channel     String         // web, whatsapp, kiosk, etc.
  sourceModel String         // modelo de IA
  prompt      String   @db.Text
  response    String   @db.Text
  latencyMs   Int
  createdAt   DateTime @default(now())

  /// IP, UA, geolocalización aproximada, flags de moderación, etc.
  metadata    Json     @default("{}")

  /// Perfil de seguridad criptográfica de la sesión (pre/híbrido/post‑Q)
  cryptoProfile String? @db.VarChar(50)

  @@index([createdAt])
  @@index([userId, channel])
}

// =====================================================
// YUN BE · JOURNALING & RECUPERACIÓN
// =====================================================

model YunBeEvent {
  id              String   @id @default(cuid())
  eventType       String
  payload         Json     @default("{}")
  status          JournalStatus @default(PENDING)
  idempotencyKey  String   @unique
  supabaseUserId  String?
  source          String   @default("system")
  federationId    String?
  ethicsScore     Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([idempotencyKey])
  @@index([eventType, status])
}

model YunBeJournal {
  id              String   @id @default(cuid())
  operationType   String
  entityType      String
  entityId        String?
  payload         Json     @default("{}")
  status          JournalStatus @default(PENDING)
  idempotencyKey  String   @unique
  supabaseUserId  String?
  stripeId        String?
  metadata        Json     @default("{}")
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([idempotencyKey])
  @@index([operationType, status])
}

model YunBeRecoveryReport {
  id                 String   @id @default(cuid())
  startedAt          DateTime @default(now())
  endedAt            DateTime?
  operationsReplayed Int      @default(0)
  incidentsCount     Int      @default(0)
  details            Json     @default("{}")
  environment        String   @default("unknown")
  createdAt          DateTime @default(now())
}

model YunBeSlackNotification {
  id              String   @id @default(cuid())
  channel         String   @default("#kernel-alerts")
  eventType       String
  message         String   @db.Text
  incidentLevel   String   @default("info")
  delivered       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

enum JournalStatus {
  PENDING
  COMPLETED
  FAILED
  RECONCILED
}

// =====================================================
// GAMIFICATION KERNEL · GUARDIANES & MISIONES
// =====================================================

model GamificationPlayer {
  id              Int      @id @default(autoincrement())
  supabaseUserId  String   @unique
  displayName     String   @default("")
  avatarId        Int?
  level           Int      @default(1)
  xp              Int      @default(0)
  virtuePoints    Int      @default(0)
  reputationScore Int      @default(2000)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  avatar          GamificationGuardian?  @relation(fields: [avatarId], references: [id])
  questLogs       GamificationQuestLog[]
  rewards         GamificationReward[]
  emotionStates   EmotionState[]
  cattleyaLinks   GamificationCattleyaLink[]
}

model GamificationGuardian {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  description   String   @db.Text
  archetype     String   @default("observador")
  primaryVirtue String   @default("calma")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  players       GamificationPlayer[]
}

model EmotionState {
  id             Int      @id @default(autoincrement())
  playerId       Int
  label          String   @default("tranquilo")
  primaryEmotion String   @default("calm")
  intensity      Float    @default(0.5)
  source         String   @default("auto")
  createdAt      DateTime @default(now())

  player         GamificationPlayer @relation(fields: [playerId], references: [id])
}

model GamificationMission {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  title          String
  description    String   @db.Text
  context        String   @default("turismo")
  xpReward       Int      @default(100)
  virtueReward   Int      @default(10)
  maxCompletions Int      @default(1)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  questLogs      GamificationQuestLog[]
}

model GamificationQuestLog {
  id          Int              @id @default(autoincrement())
  playerId    Int
  missionId   Int
  status      QuestStatus      @default(PENDING)
  progress    Float            @default(0)
  completions Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  player      GamificationPlayer  @relation(fields: [playerId], references: [id])
  mission     GamificationMission @relation(fields: [missionId], references: [id])

  @@unique([playerId, missionId])
}

enum QuestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model GamificationReward {
  id          Int        @id @default(autoincrement())
  playerId    Int
  rewardCode  String
  type        RewardType @default(BADGE)
  metadata    Json       @default("{}")
  claimedAt   DateTime   @default(now())

  player      GamificationPlayer @relation(fields: [playerId], references: [id])
}

enum RewardType {
  BADGE
  SKIN
  XR_ACCESS
  CATTLEYA_BENEFIT
}

model GamificationCattleyaLink {
  id             Int      @id @default(autoincrement())
  playerId       Int
  cattleyaUserId Int
  createdAt      DateTime @default(now())

  player         GamificationPlayer @relation(fields: [playerId], references: [id])

  @@unique([playerId, cattleyaUserId])
}

// =====================================================
// DATA GATEWAY · AUDIT LOGS & CACHE
// =====================================================

model DgAuditLog {
  id               String   @id @default(cuid())
  userId           String?
  serviceId        String?
  endpoint         String
  method           String
  params           Json     @default("{}")
  statusCode       Int
  durationMs       Int
  sourceIp         String?
  sensitivityLevel String   @default("low")
  federationId     String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
}

model DgCacheEntry {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  value     Json
  ttl       Int      @default(300)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

// =====================================================
// ARCHIVO SONORO DIGITAL · MÚSICA
// =====================================================

model MusicTrack {
  id          String   @id @default(uuid())
  title       String
  artist      String
  description String?

  coverUrl    String
  audioUrl    String

  active      Boolean  @default(true)

  // Para métricas de uso por pista
  playCount   Int      @default(0)
  lastPlayedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, createdAt])
  @@index([artist, active])
}
