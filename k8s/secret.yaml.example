# Renombrar a secret.yaml y llenar valores en base64
# echo -n "valor" | base64
apiVersion: v1
kind: Secret
metadata:
  name: supabase-credentials
  namespace: rdm-digital-hub
type: Opaque
data:
  url: <base64 SUPABASE_URL>
  anon-key: <base64 SUPABASE_ANON_KEY>
  service-role-key: <base64 SERVICE_ROLE_KEY>
---
apiVersion: v1
kind: Secret
metadata:
  name: stripe-credentials
  namespace: rdm-digital-hub
type: Opaque
data:
  secret-key: <base64 STRIPE_SECRET_KEY>
  webhook-secret: <base64 STRIPE_WEBHOOK_SECRET>
---
apiVersion: v1
kind: Secret
metadata:
  name: isabella-credentials
  namespace: rdm-digital-hub
type: Opaque
data:
  google-genai-key: <base64 GOOGLE_GENAI_API_KEY>
