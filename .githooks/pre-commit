#!/bin/sh
#
# RDM Digital Hub — Git Guardian pre-commit hook (Robust Edition)

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- 1. Verificación de entorno ---
if ! command -v gitleaks >/dev/null 2>&1; then
  if command -v docker >/dev/null 2>&1; then
    GITLEAKS_CMD="docker run --rm -v ${PWD}:/src -w /src ghcr.io/gitleaks/gitleaks:latest"
  else
    echo "${YELLOW}⚠ gitleaks no encontrado. Escaneo de secretos omitido.${NC}"
    exit 0
  fi
else
  GITLEAKS_CMD="gitleaks"
fi

# --- 2. Preparación ---
# Filtrar archivos staged (Added, Copied, Modified, Renamed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "${GREEN}🔍 Git Guardian: Iniciando escaneo...${NC}"

# --- 3. Ejecución Paralela de Comprobaciones ---
# Usamos funciones para encapsular lógica
check_secrets() {
  $GITLEAKS_CMD protect --staged --source="${PWD}" --no-banner > /dev/null 2>&1
}

check_sensitive_files() {
  # Buscamos .env y llaves privadas en un solo comando grep eficiente
  echo "$STAGED_FILES" | grep -E '\.(env|env\.local|env\.production|env\.development)$|\.(pem|key|p12|pfx)$|id_rsa$|id_ed25519$'
}

# Ejecutar comprobaciones
# Nota: gitleaks es pesado, lo ejecutamos primero
if ! check_secrets; then
  echo "${RED}❌ Git Guardian: Secretos detectados por gitleaks.${NC}"
  exit 1
fi

SENSITIVE_FOUND=$(check_sensitive_files)
if [ -n "$SENSITIVE_FOUND" ]; then
  echo "${RED}❌ Git Guardian: Archivos sensibles detectados:${NC}"
  echo "$SENSITIVE_FOUND" | sed 's/^/   /'
  exit 1
fi

echo "${GREEN}✓ Git Guardian: Escaneo exitoso.${NC}"
exit 0
